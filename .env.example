# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_TOKEN=change-me-to-a-secure-token

# Indexer
GIT_REPO_URL=https://github.com/Glukmann/RAG_test.git
GIT_BRANCH=knowledge
GIT_SOURCES_DIR=/data/git-sources
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
CHROMA_COLLECTION=lang_docs
EMBEDDING_DIMENSION=384
INDEXER_LOG_LEVEL=INFO

# Admin UI
ADMIN_API_TOKEN=change-me-to-a-secure-admin-token
ADMIN_UI_HOST=0.0.0.0
ADMIN_UI_PORT=8080

# MCP Server (chromadb-remote-mcp)
MCP_PORT=8002
MCP_AUTH_TOKEN=change-me-to-a-secure-mcp-token
MCP_LOG_LEVEL=info
